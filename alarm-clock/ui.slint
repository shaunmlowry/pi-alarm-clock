// alarm-clock — UI shell (slice 3).
//
// Four-panel navigation scaffold with live analog clock, runtime theme system,
// and themed components. Touch-only, no text input, no scrolling.
// Portrait 9:16 (480×854) surface.

import { AlarmPanel } from "AlarmPanel.slint";
import { ThemeGlobal } from "ui/ThemeGlobal.slint";
import { Card } from "ui/Card.slint";
import { Button } from "ui/Button.slint";
import { ClockFace } from "ui/ClockFace.slint";
import { NavDots } from "ui/NavDots.slint";
import { PanelTabs } from "ui/PanelTabs.slint";
import { WeatherIcon } from "ui/WeatherIcon.slint";

export { ThemeGlobal }

// ── Clock Panel ──────────────────────────────────────────────────────────
component ClockPanel inherits Rectangle {
    VerticalLayout {
        width: root.width;
        height: root.height;
        padding-top: 5px;
        padding-left: 20px;
        padding-right: 20px;
        padding-bottom: 20px;
        spacing: 16px;
        alignment: start;

        ClockFace {}

        Card {
            title: "";
            height: 72px;
            HorizontalLayout {
                padding: 0px;
                spacing: 16px;
                alignment: start;

                // Card title on the left
                Text {
                    text: "Current Conditions";
                    font-size: 18px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    vertical-alignment: center;
                }

                // Spacer to push data right
                Rectangle { horizontal-stretch: 1; }

                // Weather condition icon
                WeatherIcon {
                    wmo-code: ThemeGlobal.weather_wmo_code;
                    visible: ThemeGlobal.weather_available;
                }

                // Temperature and high/low
                VerticalLayout {
                    spacing: 0px;
                    alignment: center;

                    Text {
                        text: ThemeGlobal.weather_temp + "°C";
                        font-size: 18px;
                        color: ThemeGlobal.text-color;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }

                    Text {
                        text: ThemeGlobal.weather_high + "° / " + ThemeGlobal.weather_low + "°";
                        font-size: 13px;
                        color: ThemeGlobal.text-color;
                        opacity: 0.8;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }
                }

                // Fallback text when no weather data
                Text {
                    text: "Unavailable";
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    opacity: 0.6;
                    vertical-alignment: center;
                    visible: !ThemeGlobal.weather_available;
                }
            }
        }

        Card {
            title: "Up Next";
            height: 72px;
            Text {
                text: "Next event slot — populated by calendar slice";
                font-size: 14px;
                color: ThemeGlobal.text-color;
                font-family: ThemeGlobal.font-family;
                opacity: 0.6;
                wrap: word-wrap;
            }
        }
    }
}

// ── Daily Data Panel ──────────────────────────────────────────────────────
component DailyDataPanel inherits Rectangle {
    VerticalLayout {
        width: root.width;
        height: root.height;
        padding: 12px;
        spacing: 14px;
        alignment: start;

        PanelTabs {}

        Text {
            text: "Daily Data";
            font-size: 22px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            horizontal-alignment: center;
        }

        Card {
            title: "Today's Agenda";
            height: 120px;
            Text {
                text: "Agenda slot";
                font-size: 14px;
                color: ThemeGlobal.text-color;
                font-family: ThemeGlobal.font-family;
                opacity: 0.6;
            }
        }

        Card {
            title: "";
            height: 100px;
            HorizontalLayout {
                padding: 0px;
                spacing: 16px;
                alignment: start;

                // Card title on the left
                Text {
                    text: "Weather Tomorrow";
                    font-size: 18px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    vertical-alignment: center;
                }

                // Spacer to push data right
                Rectangle { horizontal-stretch: 1; }

                // Weather condition icon
                WeatherIcon {
                    wmo-code: ThemeGlobal.weather_wmo_code;
                    visible: ThemeGlobal.weather_available;
                }

                // Tomorrow's forecast
                VerticalLayout {
                    spacing: 0px;
                    alignment: center;

                    Text {
                        text: "Tomorrow";
                        font-size: 13px;
                        color: ThemeGlobal.text-color;
                        opacity: 0.7;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }

                    Text {
                        text: ThemeGlobal.weather_tomorrow_high + "° / " + ThemeGlobal.weather_tomorrow_low + "°";
                        font-size: 18px;
                        color: ThemeGlobal.text-color;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }
                }

                // Fallback text when no weather data
                Text {
                    text: "Unavailable";
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    opacity: 0.6;
                    vertical-alignment: center;
                    visible: !ThemeGlobal.weather_available;
                }
            }
        }

        Card {
            title: "";
            height: 100px;
            HorizontalLayout {
                padding: 0px;
                spacing: 16px;
                alignment: start;

                // Card title on the left
                Text {
                    text: "Current Conditions";
                    font-size: 18px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    vertical-alignment: center;
                }

                // Spacer to push data right
                Rectangle { horizontal-stretch: 1; }

                // Detailed current conditions on the right
                VerticalLayout {
                    spacing: 2px;
                    alignment: center;

                    Text {
                        text: "Wind: " + ThemeGlobal.weather_wind + " km/h";
                        font-size: 14px;
                        color: ThemeGlobal.text-color;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }

                    Text {
                        text: "Humidity: " + ThemeGlobal.weather_humidity + "%";
                        font-size: 14px;
                        color: ThemeGlobal.text-color;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }
                }

                // Fallback text when no weather data
                Text {
                    text: "Unavailable";
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    opacity: 0.6;
                    vertical-alignment: center;
                    visible: !ThemeGlobal.weather_available;
                }
            }
        }
    }
}

// ── Media Panel ────────────────────────────────────────────────────────────
component MediaPanel inherits Rectangle {
    VerticalLayout {
        width: root.width;
        height: root.height;
        padding: 12px;
        spacing: 14px;
        alignment: start;

        PanelTabs {}

        Text {
            text: "Media";
            font-size: 22px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            horizontal-alignment: center;
        }

        Card {
            title: "Now Playing";
            height: 120px;
            Text {
                text: "Playback slot — populated by media-player slice";
                font-size: 14px;
                color: ThemeGlobal.text-color;
                font-family: ThemeGlobal.font-family;
                opacity: 0.6;
                wrap: word-wrap;
            }
        }

        HorizontalLayout {
            alignment: center;
            spacing: 24px;
            height: 80px;

            Text {
                text: "⏮";
                font-size: 32px;
                color: ThemeGlobal.text-color;
                opacity: 0.8;
                vertical-alignment: center;
            }
            Text {
                text: "▶";
                font-size: 36px;
                color: ThemeGlobal.text-color;
                vertical-alignment: center;
            }
            Text {
                text: "⏭";
                font-size: 32px;
                color: ThemeGlobal.text-color;
                opacity: 0.8;
                vertical-alignment: center;
            }
        }

        Card {
            title: "Favorites";
            height: 140px;
            Text {
                text: "Favorites slot";
                font-size: 14px;
                color: ThemeGlobal.text-color;
                font-family: ThemeGlobal.font-family;
                opacity: 0.6;
            }
        }
    }
}

// ── Settings Panel ─────────────────────────────────────────────────────────
component InfoRow {
    in property <string> label: "";
    in property <string> value: "";

    HorizontalLayout {
        width: parent.width;
        Text {
            text: root.label;
            font-size: 16px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            opacity: 0.85;
            horizontal-stretch: 1;
        }
        Text {
            text: root.value;
            font-size: 16px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            horizontal-stretch: 0;
        }
    }
}

component SettingsPanel inherits Rectangle {
    callback theme-tapped();
    callback mode-tapped();

    VerticalLayout {
        width: root.width;
        height: root.height;
        padding: 12px;
        spacing: 14px;
        alignment: start;

        PanelTabs {}

        Text {
            text: "Settings";
            font-size: 22px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            horizontal-alignment: center;
        }

        Card {
            title: "Theme";
            height: 96px;
            tappable: true;
            tapped => { root.theme-tapped(); }

            InfoRow {
                label: "Active Theme";
                value: ThemeGlobal.active-theme-name;
            }
        }

        Card {
            title: "Mode";
            height: 96px;
            tappable: true;
            tapped => { root.mode-tapped(); }

            InfoRow {
                label: "Mode";
                value: ThemeGlobal.active-mode-name;
            }
        }

        Card {
            title: "Alarms";
            height: 96px;
            InfoRow { label: "Active Alarms"; value: "—"; }
            InfoRow { label: "Next Alarm"; value: "—"; }
        }

        Card {
            title: "Display";
            height: 96px;
            InfoRow { label: "Brightness"; value: "Auto (75%)"; }
            InfoRow { label: "Bedtime"; value: "10:00 PM - 6:00 AM"; }
        }
    }
}

// ── PanelContainer: horizontal navigation with hard stops ────────────────
component PanelContainer {
    in property <int> max-panels: 4;
    in property <bool> swipe-enabled: true;

    // Swipe origin for one-panel-per-swipe tracking.
    property <length> swipe-origin-y: 0px;
    // True once we've moved a panel during the current gesture; reset when
    // the finger lifts. Ensures one panel per swipe regardless of distance.
    property <bool> swipe-consumed: false;

    callback theme-tapped();
    callback mode-tapped();

    _ta := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: swipe-enabled;

        moved => {
            if !_ta.pressed { return; }
            if root.swipe-consumed { return; }

            let dx: float = (_ta.mouse_x - _ta.pressed_x) / 1px;
            let dy: float = (_ta.mouse_y - _ta.pressed_y) / 1px;

            // Vertical gestures are reserved for quick-controls overlay.
            if dy > 15 { return; }
            if dy < (-15) { return; }

            // Any movement past a minimal threshold triggers exactly one
            // panel change; the gesture is then consumed until finger-up.
            let threshold: float = 10;

            if dx < (-threshold) {
                if ThemeGlobal.current-panel < (max-panels - 1) {
                    ThemeGlobal.current-panel += 1;
                    root.swipe-consumed = true;
                }
            } else if dx > threshold {
                if ThemeGlobal.current-panel > 0 {
                    ThemeGlobal.current-panel -= 1;
                    root.swipe-consumed = true;
                }
            }
        }

        // Reset on finger lift so the next swipe works.
        clicked => {
            root.swipe-consumed = false;
        }
    }

    if ThemeGlobal.current-panel == 0: ClockPanel {}
    if ThemeGlobal.current-panel == 1: DailyDataPanel {}
    if ThemeGlobal.current-panel == 2: MediaPanel {}
    if ThemeGlobal.current-panel == 3: SettingsPanel {
        theme-tapped => { root.theme-tapped(); }
        mode-tapped => { root.mode-tapped(); }
    }
}

// ── AppWindow: application shell ───────────────────────────────────────────
export component AppWindow inherits Window {
    // Debug build keeps the slice-0 logical window size; release goes
    // full-screen from Rust via `set_fullscreen(true)`.
    preferred-width: 480px;
    preferred-height: 854px;
    title: "Alarm Clock";
    background: ThemeGlobal.background;

    // Episode FSM state exposed to Slint.
    in-out property <bool> episode-firing: false;

    callback dismiss-requested();
    callback snooze-requested();
    callback theme-tapped();
    callback mode-tapped();

    panel := PanelContainer {
        width: parent.width;
        height: parent.height;
        visible: !root.episode-firing;
        swipe-enabled: !root.episode-firing;
        max-panels: 4;
        theme-tapped => { root.theme-tapped(); }
        mode-tapped => { root.mode-tapped(); }
    }

    NavDots {
        y: parent.height - self.height - 8px;
        width: parent.width;
        visible: !root.episode-firing;
    }

    AlarmPanel {
        width: parent.width;
        height: parent.height;
        visible: root.episode-firing;
        dismiss-requested => { root.dismiss-requested(); }
        snooze-requested => { root.snooze-requested(); }
    }
}
