// alarm-clock — UI shell (slice 3).
//
// Four-panel navigation scaffold with live analog clock, runtime theme system,
// and themed components. Touch-only, no text input, no scrolling.
// Portrait 9:16 (480×854) surface.

import { AlarmPanel } from "AlarmPanel.slint";
import { ThemeGlobal } from "ui/ThemeGlobal.slint";
import { Card } from "ui/Card.slint";
import { Button } from "ui/Button.slint";
import { ClockFace } from "ui/ClockFace.slint";
import { NavDots } from "ui/NavDots.slint";
import { PanelTabs } from "ui/PanelTabs.slint";
import { WeatherIcon } from "ui/WeatherIcon.slint";
import { MediaPanel } from "ui/MediaPanel.slint";
import { QuickControls } from "ui/QuickControls.slint";
import { FavoriteItem, FeedEpisodeItem } from "ui/Media.slint";

export { ThemeGlobal }
export { FavoriteItem, FeedEpisodeItem }

// ── Clock Panel ──────────────────────────────────────────────────────────
component ClockPanel inherits Rectangle {
    VerticalLayout {
        width: root.width;
        height: root.height;
        padding-top: 5px;
        padding-left: 20px;
        padding-right: 20px;
        padding-bottom: 20px;
        spacing: 16px;
        alignment: start;

        ClockFace {}

        Card {
            title: "";
            height: 72px;
            HorizontalLayout {
                padding: 0px;
                spacing: 16px;
                alignment: start;

                // Card title on the left
                Text {
                    text: "Current Conditions";
                    font-size: 18px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    vertical-alignment: center;
                }

                // Spacer to push data right
                Rectangle { horizontal-stretch: 1; }

                // Weather condition icon
                WeatherIcon {
                    wmo-code: ThemeGlobal.weather_wmo_code;
                    visible: ThemeGlobal.weather_available;
                }

                // Temperature and high/low
                VerticalLayout {
                    spacing: 0px;
                    alignment: center;

                    Text {
                        text: ThemeGlobal.weather_temp + "°C";
                        font-size: 18px;
                        color: ThemeGlobal.text-color;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }

                    Text {
                        text: ThemeGlobal.weather_high + "° / " + ThemeGlobal.weather_low + "°";
                        font-size: 13px;
                        color: ThemeGlobal.text-color;
                        opacity: 0.8;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }
                }

                // Fallback text when no weather data
                Text {
                    text: "Unavailable";
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    opacity: 0.6;
                    vertical-alignment: center;
                    visible: !ThemeGlobal.weather_available;
                }
            }
        }

        Card {
            title: "Up Next";
            height: 72px;
            Text {
                text: "Next event slot — populated by calendar slice";
                font-size: 14px;
                color: ThemeGlobal.text-color;
                font-family: ThemeGlobal.font-family;
                opacity: 0.6;
                wrap: word-wrap;
            }
        }
    }
}

// ── Daily Data Panel ──────────────────────────────────────────────────────
component DailyDataPanel inherits Rectangle {
    VerticalLayout {
        width: root.width;
        height: root.height;
        padding: 12px;
        spacing: 14px;
        alignment: start;

        PanelTabs {}

        Text {
            text: "Daily Data";
            font-size: 22px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            horizontal-alignment: center;
        }

        Card {
            title: "Today's Agenda";
            height: 160px;
            VerticalLayout {
                padding: 8px;
                spacing: 6px;
                alignment: start;

                // Fallback when no agenda data is available.
                Text {
                    text: "No agenda";
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    opacity: 0.6;
                    visible: !ThemeGlobal.agenda_available;
                }

                // Up to 4 agenda items (cap 4); past events are dimmed.
                Text {
                    text: "• " + ThemeGlobal.agenda_item0;
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    opacity: ThemeGlobal.agenda_past0 ? 0.4 : 1.0;
                    visible: ThemeGlobal.agenda_count > 0;
                }
                Text {
                    text: "• " + ThemeGlobal.agenda_item1;
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    opacity: ThemeGlobal.agenda_past1 ? 0.4 : 1.0;
                    visible: ThemeGlobal.agenda_count > 1;
                }
                Text {
                    text: "• " + ThemeGlobal.agenda_item2;
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    opacity: ThemeGlobal.agenda_past2 ? 0.4 : 1.0;
                    visible: ThemeGlobal.agenda_count > 2;
                }
                Text {
                    text: "• " + ThemeGlobal.agenda_item3;
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    opacity: ThemeGlobal.agenda_past3 ? 0.4 : 1.0;
                    visible: ThemeGlobal.agenda_count > 3;
                }
            }
        }

        Card {
            title: "";
            height: 100px;
            HorizontalLayout {
                padding: 0px;
                spacing: 16px;
                alignment: start;

                // Card title on the left
                Text {
                    text: "Weather Tomorrow";
                    font-size: 18px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    vertical-alignment: center;
                }

                // Spacer to push data right
                Rectangle { horizontal-stretch: 1; }

                // Weather condition icon
                WeatherIcon {
                    wmo-code: ThemeGlobal.weather_wmo_code;
                    visible: ThemeGlobal.weather_available;
                }

                // Tomorrow's forecast
                VerticalLayout {
                    spacing: 0px;
                    alignment: center;

                    Text {
                        text: "Tomorrow";
                        font-size: 13px;
                        color: ThemeGlobal.text-color;
                        opacity: 0.7;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }

                    Text {
                        text: ThemeGlobal.weather_tomorrow_high + "° / " + ThemeGlobal.weather_tomorrow_low + "°";
                        font-size: 18px;
                        color: ThemeGlobal.text-color;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }
                }

                // Fallback text when no weather data
                Text {
                    text: "Unavailable";
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    opacity: 0.6;
                    vertical-alignment: center;
                    visible: !ThemeGlobal.weather_available;
                }
            }
        }

        Card {
            title: "";
            height: 100px;
            HorizontalLayout {
                padding: 0px;
                spacing: 16px;
                alignment: start;

                // Card title on the left
                Text {
                    text: "Current Conditions";
                    font-size: 18px;
                    color: ThemeGlobal.text-color;
                    font-family: ThemeGlobal.font-family;
                    vertical-alignment: center;
                }

                // Spacer to push data right
                Rectangle { horizontal-stretch: 1; }

                // Detailed current conditions on the right
                VerticalLayout {
                    spacing: 2px;
                    alignment: center;

                    Text {
                        text: "Wind: " + ThemeGlobal.weather_wind + " km/h";
                        font-size: 14px;
                        color: ThemeGlobal.text-color;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }

                    Text {
                        text: "Humidity: " + ThemeGlobal.weather_humidity + "%";
                        font-size: 14px;
                        color: ThemeGlobal.text-color;
                        horizontal-alignment: right;
                        visible: ThemeGlobal.weather_available;
                    }
                }

                // Fallback text when no weather data
                Text {
                    text: "Unavailable";
                    font-size: 14px;
                    color: ThemeGlobal.text-color;
                    opacity: 0.6;
                    vertical-alignment: center;
                    visible: !ThemeGlobal.weather_available;
                }
            }
        }
    }
}

// ── Media Panel ────────────────────────────────────────────────────────────
// Wraps the imported `MediaPanel` (ui/MediaPanel.slint) and adds the panel
// tab bar on top. Callbacks are forwarded to the shell's AppWindow.
component MediaPanel inherits Rectangle {
    callback favorite-tapped(int);
    callback episode-tapped(string);
    callback transport-tapped(string);

    VerticalLayout {
        width: root.width;
        height: root.height;

        PanelTabs {}

        inner := MediaPanel {
            width: root.width;
            vertical-stretch: 1;
            favorite-tapped(idx) => { root.favorite-tapped(idx); }
            episode-tapped(uri) => { root.episode-tapped(uri); }
            transport-tapped(cmd) => { root.transport-tapped(cmd); }
        }
    }
}

// ── Settings Panel ─────────────────────────────────────────────────────────
component InfoRow {
    in property <string> label: "";
    in property <string> value: "";

    HorizontalLayout {
        width: parent.width;
        Text {
            text: root.label;
            font-size: 16px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            opacity: 0.85;
            horizontal-stretch: 1;
        }
        Text {
            text: root.value;
            font-size: 16px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            horizontal-stretch: 0;
        }
    }
}

component SettingsPanel inherits Rectangle {
    callback theme-tapped();
    callback mode-tapped();
    callback pair-calendars-tapped();

    VerticalLayout {
        width: root.width;
        height: root.height;
        padding: 12px;
        spacing: 14px;
        alignment: start;

        PanelTabs {}

        Text {
            text: "Settings";
            font-size: 22px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            horizontal-alignment: center;
        }

        Card {
            title: "Theme";
            tappable: true;
            tapped => { root.theme-tapped(); }

            InfoRow {
                label: "Active Theme";
                value: ThemeGlobal.active-theme-name;
            }
        }

        Card {
            title: "Mode";
            tappable: true;
            tapped => { root.mode-tapped(); }

            InfoRow {
                label: "Mode";
                value: ThemeGlobal.active-mode-name;
            }
        }

        Card {
            title: "Alarms";
            InfoRow { label: "Active Alarms"; value: "—"; }
            InfoRow { label: "Next Alarm"; value: "—"; }
        }

        Card {
            title: "Display";
            InfoRow { label: "Brightness"; value: "Auto (75%)"; }
            InfoRow { label: "Bedtime"; value: "10:00 PM - 6:00 AM"; }
        }
    }
}

// ── Advanced Panel ───────────────────────────────────────────────────────
component AdvancedPanel inherits Rectangle {
    callback pair-calendars-tapped();

    VerticalLayout {
        width: root.width;
        height: root.height;
        padding: 12px;
        spacing: 14px;
        alignment: start;

        PanelTabs {}

        Text {
            text: "Advanced";
            font-size: 22px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
            horizontal-alignment: center;
        }

        Card {
            title: "Calendars";
            tappable: true;
            tapped => { root.pair-calendars-tapped(); }

            VerticalLayout {
                padding: 8px;
                spacing: 6px;
                alignment: start;

                // Status line: paired / re-pair needed / pairing in progress.
                InfoRow {
                    label: "Google Calendar";
                    value: ThemeGlobal.pairing_in_progress ? "Pairing…" :
                          ThemeGlobal.calendar_repair_needed ? "Re-pair needed" :
                          ThemeGlobal.configured_calendars_count > 0 ? "Paired" : "Not paired";
                }
                InfoRow {
                    label: "Calendars";
                    value: ThemeGlobal.configured_calendars_count;
                }

                // QR + user code shown while device-flow pairing is in progress.
                HorizontalLayout {
                    padding: 0px;
                    spacing: 12px;
                    alignment: start;
                    visible: ThemeGlobal.pairing_in_progress;

                    Image {
                        source: ThemeGlobal.pairing_qr_image;
                        image-fit: contain;
                        width: 96px;
                        height: 96px;
                    }
                    VerticalLayout {
                        spacing: 2px;
                        alignment: center;
                        Text {
                            text: "Visit:";
                            font-size: 13px;
                            color: ThemeGlobal.text-color;
                            font-family: ThemeGlobal.font-family;
                        }
                        Text {
                            text: ThemeGlobal.pairing_url;
                            font-size: 13px;
                            color: ThemeGlobal.text-color;
                            font-family: ThemeGlobal.font-family;
                            wrap: word-wrap;
                        }
                        Text {
                            text: "Code: " + ThemeGlobal.pairing_user_code;
                            font-size: 15px;
                            color: ThemeGlobal.text-color;
                            font-family: ThemeGlobal.font-family;
                        }
                    }
                }
            }
        }
    }
}

// ── PanelContainer: horizontal navigation with hard stops ────────────────
component PanelContainer {
    in property <int> max-panels: 4;
    in property <bool> swipe-enabled: true;

    // Swipe origin for one-panel-per-swipe tracking.
    property <length> swipe-origin-y: 0px;
    // True once we've moved a panel during the current gesture; reset when
    // the finger lifts. Ensures one panel per swipe regardless of distance.
    property <bool> swipe-consumed: false;

    callback theme-tapped();
    callback mode-tapped();
    callback pair-calendars-tapped();
    callback quick-controls-requested();
    callback favorite-tapped(int);
    callback episode-tapped(string);
    callback transport-tapped(string);

    _ta := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: swipe-enabled;

        moved => {
            if !_ta.pressed { return; }
            if root.swipe-consumed { return; }

            let dx: float = (_ta.mouse_x - _ta.pressed_x) / 1px;
            let dy: float = (_ta.mouse_y - _ta.pressed_y) / 1px;

            // Swipe up opens the quick-controls overlay (slice 7 / D3).
            if dy < (-40) {
                root.quick-controls-requested();
                root.swipe-consumed = true;
                return;
            }
            // Other vertical gestures are ignored (reserved / not a swipe).
            if dy > 15 { return; }

            // Any movement past a minimal threshold triggers exactly one
            // panel change; the gesture is then consumed until finger-up.
            let threshold: float = 10;

            if dx < (-threshold) {
                if ThemeGlobal.current-panel < (max-panels - 1) {
                    ThemeGlobal.current-panel += 1;
                    root.swipe-consumed = true;
                }
            } else if dx > threshold {
                if ThemeGlobal.current-panel > 0 {
                    ThemeGlobal.current-panel -= 1;
                    root.swipe-consumed = true;
                }
            }
        }

        // Reset on finger lift so the next swipe works.
        clicked => {
            root.swipe-consumed = false;
        }
    }

    if ThemeGlobal.current-panel == 0: ClockPanel {}
    if ThemeGlobal.current-panel == 1: DailyDataPanel {}
    if ThemeGlobal.current-panel == 2: MediaPanel {
        favorite-tapped(idx) => { root.favorite-tapped(idx); }
        episode-tapped(uri) => { root.episode-tapped(uri); }
        transport-tapped(cmd) => { root.transport-tapped(cmd); }
    }
    if ThemeGlobal.current-panel == 3: SettingsPanel {
        theme-tapped => { root.theme-tapped(); }
        mode-tapped => { root.mode-tapped(); }
    }
    if ThemeGlobal.current-panel == 4: AdvancedPanel {
        pair-calendars-tapped => { root.pair-calendars-tapped(); }
    }
}

// ── AppWindow: application shell ───────────────────────────────────────────
export component AppWindow inherits Window {
    // Debug build keeps the slice-0 logical window size; release goes
    // full-screen from Rust via `set_fullscreen(true)`.
    preferred-width: 480px;
    preferred-height: 854px;
    title: "Alarm Clock";
    background: ThemeGlobal.background;

    // Episode FSM state exposed to Slint.
    in-out property <bool> episode-firing: false;

    callback dismiss-requested();
    callback snooze-requested();
    callback theme-tapped();
    callback mode-tapped();
    callback pair-calendars-tapped();
    callback quick-controls-requested();
    callback favorite-tapped(int);
    callback episode-tapped(string);
    callback transport-tapped(string);
    callback quick-volume-changed(int);
    callback quick-brightness-changed(int);
    callback quick-dismiss-requested();

    panel := PanelContainer {
        width: parent.width;
        height: parent.height;
        visible: !root.episode-firing;
        swipe-enabled: !root.episode-firing;
        max-panels: 5;
        theme-tapped => { root.theme-tapped(); }
        mode-tapped => { root.mode-tapped(); }
        pair-calendars-tapped => { root.pair-calendars-tapped(); }
        quick-controls-requested => { root.quick-controls-requested(); }
        favorite-tapped(idx) => { root.favorite-tapped(idx); }
        episode-tapped(uri) => { root.episode-tapped(uri); }
        transport-tapped(cmd) => { root.transport-tapped(cmd); }
    }

    // Quick-controls overlay (slice 7 / D3): rendered above all panels when
    // `ThemeGlobal.quick-controls-visible` is true.
    if ThemeGlobal.quick-controls-visible: QuickControls {
        width: parent.width;
        height: parent.height;
        transport-tapped(cmd) => { root.transport-tapped(cmd); }
        volume-changed(v) => { root.quick-volume-changed(v); }
        brightness-changed(b) => { root.quick-brightness-changed(b); }
        dismiss-requested => { root.quick-dismiss-requested(); }
    }

    NavDots {
        y: parent.height - self.height - 8px;
        width: parent.width;
        visible: !root.episode-firing;
    }

    AlarmPanel {
        width: parent.width;
        height: parent.height;
        visible: root.episode-firing;
        dismiss-requested => { root.dismiss-requested(); }
        snooze-requested => { root.snooze-requested(); }
    }
}
