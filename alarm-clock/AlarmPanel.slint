// AlarmPanel.slint — alarm episode UI (slice 3).
//
// Rendered above the navigation container when an episode is `Firing`. It
// inherits the active theme via `ThemeGlobal`, so it re-renders instantly when
// the user switches themes mid-episode.

import { ThemeGlobal } from "ui/ThemeGlobal.slint";
import { Button } from "ui/Button.slint";

export component AlarmPanel inherits Rectangle {
    callback dismiss-requested();
    callback snooze-requested();

    background: ThemeGlobal.background;

    // Clock face placeholder, now theme-bound.
    Rectangle {
        background: ThemeGlobal.clock-face-background;
        width: parent.width;
        height: parent.height;

        Text {
            horizontal-alignment: center;
            vertical-alignment: center;
            text: "12:00";
            font-size: 140px;
            color: ThemeGlobal.text-color;
            font-family: ThemeGlobal.font-family;
        }
    }

    // Tap-anywhere-to-dismiss, layered beneath the Snooze button.
    dismiss-ta := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.dismiss-requested();
        }
    }

    Button {
        text: "Snooze";
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 48px;

        // Declared after dismiss-ta, so its TouchArea is hit-tested first.
        clicked => {
            root.snooze-requested();
        }
    }
}
