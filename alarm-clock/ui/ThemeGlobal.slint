// Global theme state shared between Rust and all Slint components.
// Rust writes these values on every tick and whenever the user changes theme.
import { FavoriteItem, FeedEpisodeItem } from "Media.slint";

export global ThemeGlobal {
    in-out property <color> background: #0f172a;
    in-out property <color> card-background: #ffffff;
    in-out property <color> card-border: #ffffff;
    // Lengths are stored as logical pixels and multiplied by `1px` in the
    // components. This keeps the Rust side on plain `f32` values.
    in-out property <float> card-border-width: 0;
    in-out property <float> card-shadow-blur: 0;
    in-out property <float> card-shadow-offset: 0;
    in-out property <color> card-shadow-color: #000000;
    in-out property <float> card-radius: 16;
    in-out property <color> text-color: #ffffff;
    in-out property <color> accent-color: #ff6b6b;
    in-out property <color> clock-face-background: rgba(255, 255, 255, 0.1);
    in-out property <color> hand-color: #ffffff;
    in-out property <color> second-hand-color: #ff6b6b;
    in-out property <string> font-family: "sans-serif";

    in-out property <float> hour-angle: 0;
    in-out property <float> minute-angle: 0;
    in-out property <float> second-angle: 0;
    in-out property <string> clock-weekday: "";
    in-out property <string> clock-date: "";

    in-out property <int> current-panel: 0;
    in-out property <string> active-theme-name: "Liquid Glass";
    in-out property <string> active-mode-name: "Follow Bedtime";

    // Weather data
    in-out property <string> weather_icon: "";
    in-out property <int> weather_wmo_code: 0;
    in-out property <image> weather_icon_image;
    in-out property <int> weather_frame_index: 0;
    in-out property <string> weather_temp: "";
    in-out property <string> weather_high: "";
    in-out property <string> weather_low: "";
    in-out property <string> weather_tomorrow_high: "";
    in-out property <string> weather_tomorrow_low: "";
    in-out property <string> weather_wind: "";
    in-out property <string> weather_humidity: "";
    in-out property <bool> weather_available: false;

    // Agenda (slice 6 Daily-data panel): up to 4 today's events, past dimmed.
    in-out property <string> agenda_item0: "";
    in-out property <string> agenda_item1: "";
    in-out property <string> agenda_item2: "";
    in-out property <string> agenda_item3: "";
    in-out property <bool> agenda_past0: false;
    in-out property <bool> agenda_past1: false;
    in-out property <bool> agenda_past2: false;
    in-out property <bool> agenda_past3: false;
    in-out property <int> agenda_count: 0;
    in-out property <bool> agenda_available: false;
    // True when the user must re-pair Google Calendar (task 2.3).
    in-out property <bool> calendar_repair_needed: false;
    // Device-flow pairing code + URL to display (QR / text), set during pairing.
    in-out property <string> pairing_user_code: "";
    in-out property <string> pairing_url: "";
    in-out property <image> pairing_qr_image;
    in-out property <bool> pairing_in_progress: false;
    in-out property <int> configured_calendars_count: 0;

    // Web config pairing (slice 8): QR + URL shown on the Pi touchscreen.
    in-out property <string> web_pairing_url: "";
    in-out property <string> web_pairing_ip_url: "";
    in-out property <image> web_pairing_qr_image;
    in-out property <bool> web_pairing_in_progress: false;

    // Neuromorphic cards need a dual-extrusion shadow. This flag lets a
    // single `Card` component branch between the two rendering techniques.
    in-out property <bool> is-neuromorphic: false;

    // ── Media panel (slice 7) ────────────────────────────────────────
    // Now-playing line (track / artist / stream name).
    in-out property <string> media-now-playing: "";
    // Horizontal offset for marquee scrolling when text overflows.
    in-out property <float> media-now-playing-offset: 0;
    // True while a track is actively playing (drives play/pause glyph).
    in-out property <bool> media-playing: false;
    // True while playback is buffering (drives a spinner in place of the
    // transport glyph).
    in-out property <bool> media-buffering: false;
    // Spinner frame index (0..3) for the buffering indicator.
    in-out property <int> media-spinner-frame: 0;
    // Transport capability flags (derived from the active source).
    in-out property <bool> media-caps-play: false;
    in-out property <bool> media-caps-pause: false;
    in-out property <bool> media-caps-stop: false;
    in-out property <bool> media-caps-next: false;
    in-out property <bool> media-caps-prev: false;
    in-out property <bool> media-caps-seek: false;
    // Favorites list (Pi cap 8) + expanded podcast episode list.
    in-out property <[FavoriteItem]> media-favorites: [];
    in-out property <[FeedEpisodeItem]> media-episodes: [];
    // Index of the expanded podcast favorite (-1 = none).
    in-out property <int> media-expanded-index: -1;

    // ── Quick-controls overlay (slice 7 / D3) ────────────────────────
    in-out property <bool> quick-controls-visible: false;
    // Volume / brightness slider values (0..=100).
    in-out property <int> quick-volume: 50;
    in-out property <int> quick-brightness: 60;
}
